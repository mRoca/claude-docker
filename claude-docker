#!/usr/bin/env bash
set -euo pipefail

IMAGE="claude-docker:latest"

# Portable alternative to readlink -f (which is unavailable on macOS)
resolve_path() {
    local target="$1"
    cd "$(dirname "$target")"
    target="$(basename "$target")"
    while [[ -L "$target" ]]; do
        target="$(readlink "$target")"
        cd "$(dirname "$target")"
        target="$(basename "$target")"
    done
    echo "$(pwd -P)/$target"
}
SCRIPT_DIR="$(dirname "$(resolve_path "${BASH_SOURCE[0]}")")"

# Load local config (gitignored); fall back to defaults
CLIPBOARD_FORWARDING=false
if [[ -f "$SCRIPT_DIR/claude-docker.env" ]]; then
    # shellcheck source=/dev/null
    source "$SCRIPT_DIR/claude-docker.env"
fi

# Build the image if it doesn't exist or if --build is passed
if [[ "${1:-}" == "--build" ]]; then
    shift
    docker build --no-cache -f "$SCRIPT_DIR/Dockerfile" -t "$IMAGE" "$SCRIPT_DIR"
    exit 0
elif ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Image $IMAGE not found. Building..." >&2
    docker build -f "$SCRIPT_DIR/Dockerfile" -t "$IMAGE" "$SCRIPT_DIR"
fi

# Detect OS — on macOS, Docker Desktop's Linux VM handles file ownership
# transparently, so we skip UID/GID and group mapping.
OS="$(uname -s)"
USER_ARGS=()
if [[ "$OS" != "Darwin" ]]; then
    USER_ARGS+=(-u "$(id -u):$(id -g)")
    for gid in $(id -G); do
        USER_ARGS+=(--group-add "$gid")
    done
fi

# Let's persist the claude files or share the existing config
mkdir -p "$HOME/.claude"

CLAUDE_JSON_ARGS=()
if [[ -f "$HOME/.claude.json" ]]; then
    CLAUDE_JSON_ARGS+=(-v "$HOME/.claude.json:$HOME/.claude.json")
fi

# Clipboard forwarding so Ctrl+V image paste works inside the container
CLIPBOARD_ARGS=()
if [[ "$CLIPBOARD_FORWARDING" == "true" && "$OS" != "Darwin" ]]; then
    if [[ -n "${WAYLAND_DISPLAY:-}" && -n "${XDG_RUNTIME_DIR:-}" ]]; then
        # Wayland: mount the socket so wl-paste can reach it
        CLIPBOARD_ARGS+=(
            -e WAYLAND_DISPLAY="$WAYLAND_DISPLAY"
            -e XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR"
            -v "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY:$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"
        )
    elif [[ -n "${DISPLAY:-}" ]]; then
        # X11: forward display + authority file so xclip can reach the X server
        CLIPBOARD_ARGS+=(
            -e DISPLAY="$DISPLAY"
            -v /tmp/.X11-unix:/tmp/.X11-unix
        )
        if [[ -f "${XAUTHORITY:-$HOME/.Xauthority}" ]]; then
            CLIPBOARD_ARGS+=(
                -e XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"
                -v "${XAUTHORITY:-$HOME/.Xauthority}:${XAUTHORITY:-$HOME/.Xauthority}"
            )
        fi
    fi
fi

exec docker run --rm -it \
    "${USER_ARGS[@]}" \
    -v "$(pwd):$(pwd)" \
    -w "$(pwd)" \
    -e HOME="$HOME" \
    -e USER="${USER:-$(id -un)}" \
    ${ANTHROPIC_API_KEY:+-e ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY"} \
    ${CLAUDE_CODE_OAUTH_TOKEN:+-e CLAUDE_CODE_OAUTH_TOKEN="$CLAUDE_CODE_OAUTH_TOKEN"} \
    -v "$HOME/.claude:$HOME/.claude" \
    "${CLAUDE_JSON_ARGS[@]}" \
    "${CLIPBOARD_ARGS[@]}" \
    "$IMAGE" \
    "$@"
