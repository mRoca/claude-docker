# claude-docker configuration
# Copy this file to claude-docker.env and adjust to your needs.
# claude-docker.env is gitignored — your local settings won't be committed.

# ---------------------------------------------------------------------------
# CLIPBOARD_FORWARDING — allow Ctrl+V image paste inside the container
# ---------------------------------------------------------------------------
# When enabled, the display server socket is forwarded into the container so
# that Claude Code can read the clipboard directly (required for image paste).
#
# Disabled by default because forwarding the socket grants every process
# running inside the container access to your desktop session, beyond just
# the clipboard. The exact exposure depends on your display server:
#
# X11 — HIGH RISK
#   X11 has no isolation between clients. Any process in the container can:
#     - Record keystrokes from any window on your desktop (keylogger)
#     - Take screenshots of your entire screen
#     - Inject mouse/keyboard input into other applications
#     - Read the clipboard continuously
#   Avoid enabling this on X11 unless you fully trust everything Claude runs.
#
# Wayland — MODERATE RISK
#   Wayland isolates windows between clients, so keylogging and input
#   injection into other apps are not possible. However, a process in the
#   container can still:
#     - Read the clipboard at any time (not only during a paste event)
#     - Write to the clipboard
#     - Take screenshots, depending on your compositor and exposed protocols
#       (wlr-screencopy is available on most wlroots-based compositors such
#       as sway, Hyprland, river, etc.)
#   The risk is significantly lower than X11 but not zero.
#
# Set to "true" to enable, "false" (default) to disable.
CLIPBOARD_FORWARDING=false
